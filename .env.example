# === Database ===
# For hosted Postgres/Neon, prefer sslmode=verify-full to avoid pg SSL-mode warnings.
DATABASE_URL="postgresql://mockupai:password@localhost:5432/mockupai"

# === Redis ===
REDIS_URL="redis://localhost:6379"

# === Auth ===
SESSION_SECRET="change-this-to-a-random-32-char-string"

# === Admin Seed ===
ADMIN_EMAIL="admin@mockupai.local"
ADMIN_PASSWORD="changeme123"

# === App ===
NEXT_PUBLIC_APP_NAME="MockupAI"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# === Server ===
PORT=3000

# === Locale ===
APP_LOCALE="vi"
NEXT_PUBLIC_APP_LOCALE="vi"

# === Internal/Dev Controls ===
PUBLISH_DRY_RUN="false"
MOCKUP_FALLBACK_FORCE="false"
FEATURE_FLAG_DEBUG_UI="false"

# === AI Providers ===
# These are optional ENV fallbacks. Admin can also store encrypted keys from the AI Settings page.
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# === AI Hub / Codex Web ===
# Shared secret used only by Codex Web -> app internal workspace allowlist calls.
AI_HUB_INTERNAL_TOKEN="change-this-internal-ai-hub-token"
# Local dev defaults. On VPS, use stable service-user writable paths such as /srv/ai-hub.
AI_HUB_MEMBERS_ROOT="/tmp/ai-hub/members"
AI_HUB_SHARED_ROOT="/tmp/ai-hub/common"
# Isolated HOME for the shared Codex runtime. Prevents AI Hub from showing a developer's personal Codex history.
AI_HUB_RUNTIME_HOME="/tmp/ai-hub/codex-runtime/home"
# Optional: keep npx cache outside AI_HUB_RUNTIME_HOME so Codex Web startup does not depend on a fresh runtime HOME.
AI_HUB_NPM_CACHE=""
# Codex Web must bind locally; public browser access goes through /api/codex-proxy.
CODEX_APP_URL="http://127.0.0.1:8214"
AI_HUB_CODEX_WEB_REF="git+ssh://git@github.com/tranquoctuyen97/codex-web.git#main"
AI_HUB_CODEX_WEB_PORT="8214"
CODEX_CLI_PATH="/home/codexbot/.local/bin/codex"
AI_HUB_WORKSPACES_URL="http://127.0.0.1:3001/api/internal/ai-hub/workspaces?provider=codex"
AI_HUB_GATEWAY_PORT="8215"
AI_HUB_APP_ORIGIN="http://127.0.0.1:3001"
AI_HUB_IFRAME_URL="/api/codex-proxy/"

# === Encryption ===
MASTER_ENCRYPTION_KEY_ID="v1"
MASTER_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# === Inkhub Auto-Fulfill Platform ===
INKHUB_USERNAME=
INKHUB_PASSWORD=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# === RT + Gmail Mailbox Integration ===
# Use the production RT stack at http://127.0.0.1:8082, or the disposable lab at http://127.0.0.1:18082.
RT_URL="http://127.0.0.1:8082"
# Create in RT Preferences -> Authentication Tokens.
RT_API_TOKEN=""
RT_GMAIL_LABELS_CUSTOM_FIELD="Gmail Labels"
MAILBOX_SYNC_POLL_INTERVAL_MS=60000
MAILBOX_RUNTIME_DIR="/var/lib/mockupai-mailboxes"

# Disposable Gmail/RT verification only. Never use production mailboxes.
GMAIL_TEST_USER=""
GMAIL_TEST_APP_PASSWORD=""
GMAIL_TEST_USER_B=""
GMAIL_TEST_APP_PASSWORD_B=""
