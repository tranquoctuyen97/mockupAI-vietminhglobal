RT_POSTGRES_PORT=5432
RT_POSTGRES_DB=mockupai_rt
RT_POSTGRES_USER=mockupai
RT_POSTGRES_PASSWORD=change-me
RT_WEB_DOMAIN=127.0.0.1
RT_WEB_PORT=8082
RT_WEB_PATH=
RT_LOG_LEVEL=info

APP_DATABASE_URL=postgresql://mockupai:password@mockupai-postgres:5432/mockupai
APP_REDIS_URL=redis://mockupai-redis:6379
RT_URL=http://rt:9000
# This is auto-created by ./setup-dev.sh when it bootstraps RT.
RT_API_TOKEN=
MASTER_ENCRYPTION_KEY_ID=v1
MASTER_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
MAILBOX_SYNC_POLL_INTERVAL_MS=60000

# Optional host-side Task 16 live-matrix inputs. Keep these out of Git.
GMAIL_TEST_USER=
GMAIL_TEST_APP_PASSWORD=
GMAIL_TEST_USER_B=
GMAIL_TEST_APP_PASSWORD_B=
