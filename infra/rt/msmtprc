defaults
auth on
tls on
tls_starttls on
logfile -

# Per-mailbox account blocks are generated into /run/mockupai-mailboxes/configs.
# Each block uses:
# account mailbox_<id>
# host smtp.gmail.com
# port 587
# from <gmail address>
# user <gmail address>
# passwordeval /usr/local/bin/mailbox-secret-helper <mailbox id>
#
# msmtp selects an account by envelope-from via --read-envelope-from.
include /run/mockupai-mailboxes/configs/*.msmtprc
