generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Multi-tenant ready: mọi bảng có tenant_id dù v1 single-tenant
// ============================================================

model Tenant {
  id         String   @id @default(cuid())
  name       String
  createdAt  DateTime @default(now()) @map("created_at")
  twTimezone String   @default("America/Los_Angeles") @map("tw_timezone")

  users              User[]
  auditEvents        AuditEvent[]
  stores             Store[]
  wizardDrafts       WizardDraft[]
  rolePermissions    TenantRolePermission[]
  inkhubCredential   InkhubCredential?
  twCredentials      TripleWhaleCredential[]
  mockupLibraryItems MockupLibraryItem[]
  mailboxes          Mailbox[]
  responseMetrics    MailboxResponseMetric[]
  aiHubWorkspaces    AiHubWorkspace[]

  @@map("tenants")
}

model User {
  id                 String     @id @default(cuid())
  tenantId           String     @map("tenant_id")
  email              String     @unique
  passwordHash       String     @map("password_hash")
  role               UserRole   @default(OPERATOR)
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean    @default(true) @map("must_change_password")
  createdBy          String?    @map("created_by")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  tenant                     Tenant              @relation(fields: [tenantId], references: [id])
  sessions                   Session[]
  uploadedMockupLibraryItems MockupLibraryItem[] @relation("MockupLibraryUploadedBy")
  mailboxResponseMetrics     MailboxResponseMetric[] @relation("MailboxResponseLatestReplyActor")
  mailboxInternalNotes       MailboxInternalNote[] @relation("MailboxInternalNoteActor")
  mailboxComposerAttachments MailboxComposerAttachment[] @relation("MailboxComposerAttachmentUploadedBy")
  mailboxSkippedSenders      MailboxSkippedSender[] @relation("MailboxSkippedSenderCreatedBy")
  aiHubMemberWorkspaces      AiHubMemberWorkspace[]

  @@index([tenantId])
  @@index([email, status])
  @@index([tenantId, role])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model TenantRolePermission {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  role      UserRole
  feature   String
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, role, feature])
  @@index([tenantId, role])
  @@map("tenant_role_permissions")
}

model AiHubWorkspace {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  path      String
  type      String
  provider  String   @default("codex")
  createdAt DateTime @default(now()) @map("created_at")

  tenant  Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members AiHubMemberWorkspace[]

  @@unique([tenantId, provider, path])
  @@index([tenantId, provider, type])
  @@map("ai_hub_workspaces")
}

model AiHubMemberWorkspace {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace AiHubWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("ai_hub_member_workspaces")
}

model InkhubCredential {
  id                String   @id @default(cuid())
  tenantId          String   @unique @map("tenant_id")
  username          String
  passwordEncrypted Bytes    @map("password_encrypted")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("inkhub_credentials")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  userAgent String?  @map("user_agent")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([tokenHash])
  @@map("sessions")
}

model AuditEvent {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  actorUserId  String?  @map("actor_user_id")
  action       String // e.g. "user.created", "store.connected"
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id")
  metadata     Json? // Flexible JSONB for extra context
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([resourceType, resourceId])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

model FeatureFlag {
  key            String   @id
  enabled        Boolean  @default(false)
  description    String?
  rolloutPercent Int      @default(100) @map("rollout_percent")
  updatedBy      String?  @map("updated_by")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([enabled])
  @@map("feature_flags")
}

// ============================================================
// PHASE 6.5 — Printify Integration (workspace-level)
// ============================================================

model PrintifyAccount {
  id              String                @id @default(cuid())
  tenantId        String                @map("tenant_id")
  nickname        String // "Main Account", "Backup"
  apiKeyEncrypted Bytes                 @map("api_key_encrypted")
  encryptionKeyId String                @map("encryption_key_id")
  status          PrintifyAccountStatus @default(ACTIVE)
  lastSyncAt      DateTime?             @map("last_sync_at")
  lastHealthCheck DateTime?             @map("last_health_check")
  createdBy       String?               @map("created_by")
  createdAt       DateTime              @default(now()) @map("created_at")
  rotatedAt       DateTime              @default(now()) @map("rotated_at")

  shops PrintifyShop[]

  @@unique([tenantId, nickname])
  @@index([tenantId, status])
  @@map("printify_accounts")
}

enum PrintifyAccountStatus {
  ACTIVE
  TOKEN_INVALID
  DISABLED
}

model PrintifyShop {
  id                String   @id @default(cuid())
  printifyAccountId String   @map("printify_account_id")
  externalShopId    Int      @map("external_shop_id") // Printify's numeric shop ID
  title             String
  salesChannel      String?  @map("sales_channel") // shopify|custom|etsy
  externalDomain    String?  @map("external_domain") // domain if native Shopify
  disconnected      Boolean  @default(false)
  syncedAt          DateTime @default(now()) @map("synced_at")

  account PrintifyAccount @relation(fields: [printifyAccountId], references: [id], onDelete: Cascade)
  stores  Store[] // reverse relation — shops linked by stores

  @@unique([printifyAccountId, externalShopId])
  @@map("printify_shops")
}

// ============================================================
// PHASE 1 — Store Connection
// ============================================================

model Store {
  id                String      @id @default(cuid())
  tenantId          String      @map("tenant_id")
  name              String
  shopifyDomain     String      @map("shopify_domain") // mystore.myshopify.com
  shopifyShopId     String?     @map("shopify_shop_id") // gid://shopify/Shop/...
  printifyShopId    String?     @unique @map("printify_shop_id") // 1 shop = 1 store
  printifyShopTitle String?     @map("printify_shop_title") // Cached shop display name
  status            StoreStatus @default(ACTIVE)
  lastHealthCheck   DateTime?   @map("last_health_check")
  createdBy         String?     @map("created_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  // Phase 6.10 — Store-level preset fields (price/publish stay on Store)
  defaultPriceUsd Decimal @default(24.99) @map("default_price_usd") @db.Decimal(10, 2)
  publishMode     String  @default("draft") @map("publish_mode") // 'draft' | 'active'

  tenant             Tenant                @relation(fields: [tenantId], references: [id])
  printifyShop       PrintifyShop?         @relation(fields: [printifyShopId], references: [id], onDelete: SetNull)
  credentials        StoreCredentials?
  colors             StoreColor[]
  templates          StoreMockupTemplate[]
  wizardDrafts       WizardDraft[]
  listings           Listing[]
  designs            Design[]
  mockupLibraryItems MockupLibraryItem[]
  mailboxes          Mailbox[]
  responseMetrics    MailboxResponseMetric[]

  @@unique([tenantId, shopifyDomain])
  @@index([tenantId, status])
  @@map("stores")
}

enum StoreStatus {
  ACTIVE
  TOKEN_EXPIRED
  ERROR
}

model StoreCredentials {
  storeId                String   @id @map("store_id")
  shopifyClientId        String   @map("shopify_client_id")
  shopifyClientSecretEnc Bytes    @map("shopify_client_secret_enc")
  shopifyTokenEncrypted  Bytes?   @map("shopify_token_encrypted")
  encryptionKeyId        String   @map("encryption_key_id")
  rotatedAt              DateTime @default(now()) @map("rotated_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_credentials")
}

model StoreColor {
  id              String  @id @default(cuid())
  storeId         String  @map("store_id")
  name            String
  hex             String
  colorGroup      String  @default("auto") @map("color_group")
  printifyColorId String? @map("printify_color_id")
  enabled         Boolean @default(true)
  sortOrder       Int     @default(0) @map("sort_order")

  store          Store                          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  templateColors TemplateColor[]
  libraryPicks   WizardDraftMockupLibraryPick[]

  @@unique([storeId, name])
  @@index([storeId])
  @@map("store_colors")
}

model StoreMockupTemplate {
  id                      String                      @id @default(cuid())
  storeId                 String                      @map("store_id")
  name                    String
  printifyBlueprintId     Int                         @map("printify_blueprint_id")
  printifyPrintProviderId Int                         @map("printify_print_provider_id")
  blueprintTitle          String                      @default("") @map("blueprint_title")
  printProviderTitle      String                      @default("") @map("print_provider_title")
  previewUrl              String?                     @map("preview_url")
  position                TemplatePosition            @default(FRONT)
  isDefault               Boolean                     @default(false) @map("is_default")
  sortOrder               Int                         @default(0) @map("sort_order")
  // Phase 6.10 — Template-level preset fields
  enabledVariantIds       Int[]                       @default([]) @map("enabled_variant_ids")
  enabledSizes            String[]                    @default([]) @map("enabled_sizes")
  // Per-color size selection: { "Black": ["S","M","L"], "Heather Red": ["S","M"] }
  enabledSizesByColor     Json?                       @map("enabled_sizes_by_color")
  defaultPlacement        Json?                       @map("default_placement")
  defaultAspectRatio      String                      @default("1:1") @map("default_aspect_ratio")
  storePresetSnapshot     Json?                       @map("store_preset_snapshot")
  schemaVersion           Int                         @default(1) @map("schema_version")
  // UI Improvement — dynamic print area per view (Sprint 2.1)
  printAreasByView        Json?                       @map("print_areas_by_view")
  // UI Improvement — blueprint metadata cache (Sprint 4.1)
  blueprintImageUrl       String?                     @map("blueprint_image_url")
  blueprintBrand          String?                     @map("blueprint_brand")
  defaultMockupSource     TemplateDefaultMockupSource @default(PRINTIFY) @map("default_mockup_source")
  basePriceUsd            Decimal?                    @map("base_price_usd") @db.Decimal(10, 2)
  priceBySizeDefault      Json?                       @map("price_by_size_default")
  defaultTags             String[]                    @default([]) @map("default_tags")

  store        Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  colors       TemplateColor[]
  listings     Listing[]
  wizardDrafts WizardDraft[]
  mockupItems  TemplateMockupItem[]

  @@index([storeId])
  @@map("store_mockup_templates")
}

model TemplateColor {
  id         String @id @default(cuid())
  templateId String @map("template_id")
  colorId    String @map("color_id")
  sortOrder  Int    @default(0) @map("sort_order")

  template StoreMockupTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  color    StoreColor          @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@unique([templateId, colorId])
  @@index([templateId])
  @@map("template_colors")
}

enum TemplatePosition {
  FRONT
  BACK
  SLEEVE
}

enum TemplateDefaultMockupSource {
  PRINTIFY
  CUSTOM
}

enum MockupLibraryRenderMode {
  COMPOSITE
}

enum MockupLibraryView {
  front
  back
  sleeve_left
  sleeve_right
  detail
  lifestyle
}

enum MockupLibraryScene {
  flat_lay
  hanging
  lifestyle
  model
  detail
}

enum WizardMockupSourceMode {
  AUTO
  TEMPLATE_PRINTIFY
  DRAFT_CUSTOM
}

model MockupLibraryItem {
  id                String                  @id @default(cuid())
  tenantId          String                  @map("tenant_id")
  storeId           String                  @map("store_id")
  name              String
  storagePath       String                  @map("storage_path")
  previewPath       String?                 @map("preview_path")
  width             Int
  height            Int
  view              MockupLibraryView
  sceneType         MockupLibraryScene      @map("scene_type")
  renderMode        MockupLibraryRenderMode @default(COMPOSITE) @map("render_mode")
  compositeRegionPx Json?                   @map("composite_region_px")
  uploadedById      String?                 @map("uploaded_by_id")
  mimeType          String                  @map("mime_type")
  fileSizeBytes     Int                     @map("file_size_bytes")
  isActive          Boolean                 @default(true) @map("is_active")
  deletedAt         DateTime?               @map("deleted_at")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store         Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  uploadedBy    User?                @relation("MockupLibraryUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  templateItems TemplateMockupItem[]

  @@index([tenantId, storeId, isActive, deletedAt])
  @@index([tenantId, name])
  @@map("mockup_library_items")
}

model TemplateMockupItem {
  id                String   @id @default(cuid())
  templateId        String   @map("template_id")
  mockupId          String   @map("mockup_id")
  appliesToColorIds Json     @default("[]") @map("applies_to_color_ids")
  sortOrder         Int      @default(0) @map("sort_order")
  isPrimary         Boolean  @default(false) @map("is_primary")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  template StoreMockupTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  mockup   MockupLibraryItem              @relation(fields: [mockupId], references: [id], onDelete: Restrict)
  picks    WizardDraftMockupLibraryPick[]

  @@unique([templateId, mockupId])
  @@index([templateId, isPrimary, sortOrder])
  @@index([mockupId])
  @@map("template_mockup_items")
}

// ============================================================
// PHASE 2 — Design Library
// ============================================================

model Design {
  id               String       @id @default(cuid())
  tenantId         String       @map("tenant_id")
  storeId          String?      @map("store_id")
  ownerUserId      String       @map("owner_user_id")
  name             String
  originalFilename String       @map("original_filename")
  storagePath      String       @map("storage_path")
  previewPath      String?      @map("preview_path")
  width            Int
  height           Int
  dpi              Int?
  fileSizeBytes    Int          @map("file_size_bytes")
  mimeType         String       @map("mime_type")
  status           DesignStatus @default(ACTIVE)
  deletedAt        DateTime?    @map("deleted_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  store        Store?              @relation(fields: [storeId], references: [id], onDelete: SetNull)
  usages       DesignUsage[]
  wizardDrafts WizardDraft[]
  draftDesigns WizardDraftDesign[]
  mockupJobs   MockupJob[]

  @@index([tenantId, status])
  @@index([tenantId, storeId, status])
  @@index([tenantId, name])
  @@map("designs")
}

enum DesignStatus {
  ACTIVE
  DELETED
}

model DesignUsage {
  designId  String @map("design_id")
  listingId String @map("listing_id")

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@id([designId, listingId])
  @@map("design_usage")
}

// ============================================================
// PHASE 3 — Wizard + Mockup Engine
// ============================================================

model WizardDraft {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")
  designId String? @map("design_id")
  storeId  String? @map("store_id")

  aiContent                 Json?                  @map("ai_content") // Phase 4: title, desc, tags, etc.
  currentStep               Int                    @default(1) @map("current_step")
  status                    DraftStatus            @default(DRAFT)
  // Phase 6.9: mockup stale detection
  mockupsStale              Boolean                @default(false) @map("mockups_stale")
  mockupsStaleReason        String?                @map("mockups_stale_reason")
  // Phase 6.10: variants user keeps after tick/untick at step-3 Preview
  enabledVariantIdsOverride Int[]                  @default([]) @map("enabled_variant_ids_override")
  // Phase 6.10: new fields
  enabledColorIds           String[]               @default([]) @map("enabled_color_ids")
  enabledSizes              String[]               @default([]) @map("enabled_sizes")
  // Per-color size selection: { colorName → string[] }. Null = use enabledSizes as fallback.
  enabledSizesByColor       Json?                  @map("enabled_sizes_by_color")
  placementOverride         Json?                  @map("placement_override")
  // Per-size retail price override: { sizeName → priceUSD }. Null = auto-calculate (base + costDelta).
  priceBySizeOverride       Json?                  @map("price_by_size_override")
  printifyDraftProductId    String?                @map("printify_draft_product_id")
  printifyImageId           String?                @map("printify_image_id")
  // Custom mockup source mode
  mockupSourceMode          WizardMockupSourceMode @default(AUTO) @map("mockup_source_mode")
  updatedAt                 DateTime               @updatedAt @map("updated_at")

  mockupJobs         MockupJob[]
  draftDesigns       WizardDraftDesign[]
  designPairs        WizardDraftDesignPair[]
  listings           Listing[]
  design             Design?                        @relation(fields: [designId], references: [id])
  tenant             Tenant                         @relation(fields: [tenantId], references: [id])
  store              Store?                         @relation(fields: [storeId], references: [id])
  templateId         String?                        @map("template_id")
  template           StoreMockupTemplate?           @relation(fields: [templateId], references: [id], onDelete: SetNull)
  mockupLibraryPicks WizardDraftMockupLibraryPick[]

  @@index([tenantId, updatedAt])
  @@map("wizard_drafts")
}

model WizardDraftDesign {
  id                     String   @id @default(cuid())
  draftId                String   @map("wizard_draft_id")
  designId               String   @map("design_id")
  sortOrder              Int      @default(0) @map("sort_order")
  printifyImageId        String?  @map("printify_image_id")
  printifyDraftProductId String?  @map("printify_draft_product_id")
  lastError              String?  @map("last_error")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  aiContent Json? @map("ai_content")

  draft      WizardDraft             @relation(fields: [draftId], references: [id], onDelete: Cascade)
  design     Design                  @relation(fields: [designId], references: [id], onDelete: Cascade)
  jobs       MockupJob[]
  listings   Listing[]
  lightPairs WizardDraftDesignPair[] @relation("PairLightDesign")
  darkPairs  WizardDraftDesignPair[] @relation("PairDarkDesign")

  @@unique([draftId, designId])
  @@index([draftId, sortOrder])
  @@index([designId])
  @@map("wizard_draft_designs")
}

model WizardDraftDesignPair {
  id                 String   @id @default(cuid())
  draftId            String   @map("wizard_draft_id")
  baseName           String   @map("base_name")
  lightDraftDesignId String   @map("light_draft_design_id")
  darkDraftDesignId  String   @map("dark_draft_design_id")
  sortOrder          Int      @default(0) @map("sort_order")
  aiContent          Json?    @map("ai_content")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  draft       WizardDraft       @relation(fields: [draftId], references: [id], onDelete: Cascade)
  lightDesign WizardDraftDesign @relation("PairLightDesign", fields: [lightDraftDesignId], references: [id], onDelete: Cascade)
  darkDesign  WizardDraftDesign @relation("PairDarkDesign", fields: [darkDraftDesignId], references: [id], onDelete: Cascade)
  listing     Listing?

  @@unique([draftId, baseName])
  @@unique([draftId, lightDraftDesignId])
  @@unique([draftId, darkDraftDesignId])
  @@index([draftId, sortOrder])
  @@map("wizard_draft_design_pairs")
}

model WizardDraftMockupLibraryPick {
  id                   String   @id @default(cuid())
  draftId              String   @map("wizard_draft_id")
  templateMockupItemId String   @map("template_mockup_item_id")
  colorId              String   @map("color_id")
  isPrimary            Boolean  @default(false) @map("is_primary")
  sortOrder            Int      @default(0) @map("sort_order")
  compositeRegionPx    Json?    @map("composite_region_px")
  createdAt            DateTime @default(now()) @map("created_at")

  draft              WizardDraft        @relation(fields: [draftId], references: [id], onDelete: Cascade)
  templateMockupItem TemplateMockupItem @relation(fields: [templateMockupItemId], references: [id], onDelete: Restrict)
  color              StoreColor         @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@unique([draftId, templateMockupItemId, colorId])
  @@index([draftId, colorId])
  @@index([templateMockupItemId])
  @@map("wizard_draft_mockup_library_picks")
}

enum DraftStatus {
  DRAFT
  GENERATING
  READY
  PUBLISHED
  ABANDONED
}

model MockupImage {
  id               String   @id @default(cuid())
  mockupJobId      String   @map("mockup_job_id")
  printifyMockupId String   @map("printify_mockup_id")
  variantId        Int      @map("variant_id")
  colorName        String   @map("color_name")
  viewPosition     String   @map("view_position")
  sourceUrl        String   @map("source_url")
  compositeUrl     String?  @map("composite_url")
  compositeStatus  String   @default("pending") @map("composite_status") // pending | processing | completed | failed
  compositeError   String?  @map("composite_error")
  included         Boolean  @default(false)
  mockupType       String   @default("front") @map("mockup_type")
  isDefault        Boolean  @default(false) @map("is_default")
  cameraLabel      String?  @map("camera_label")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  mockupJob MockupJob @relation(fields: [mockupJobId], references: [id], onDelete: Cascade)

  @@index([mockupJobId, variantId])
  @@index([mockupJobId, isDefault])
  @@map("mockup_images")
}

model MockupJob {
  id                String   @id @default(cuid())
  draftId           String   @map("wizard_draft_id")
  draftDesignId     String?  @map("wizard_draft_design_id")
  designId          String?  @map("design_id")
  status            String   @default("pending") // pending | running | completed | failed
  totalImages       Int      @default(0) @map("total_images")
  completedImages   Int      @default(0) @map("completed_images")
  failedImages      Int      @default(0) @map("failed_images")
  errorMessage      String?  @map("error_message")
  placementSnapshot Json     @map("placement_snapshot") // PlacementData at job creation time
  colorFilterIds    Json?    @map("color_filter_ids")
  colorGroup        String?  @map("color_group")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  draft       WizardDraft        @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftDesign WizardDraftDesign? @relation(fields: [draftDesignId], references: [id], onDelete: Cascade)
  design      Design?            @relation(fields: [designId], references: [id], onDelete: SetNull)
  images      MockupImage[]

  @@index([draftId, status])
  @@index([draftId, draftDesignId, status])
  @@index([draftDesignId])
  @@index([designId])
  @@map("mockup_jobs")
}

