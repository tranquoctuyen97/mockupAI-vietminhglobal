enum ListingStatus {
  PUBLISHING
  ACTIVE
  PARTIAL_FAILURE
  FAILED
}

enum PublishStage {
  SHOPIFY
  PRINTIFY
}

model Listing {
  id                      String        @id @default(cuid())
  tenantId                String        @map("tenant_id")
  storeId                 String?       @map("store_id")
  designId                String?       @map("design_id")
  templateId              String?       @map("template_id")
  wizardDraftId           String?       @map("wizard_draft_id")
  wizardDraftDesignId     String?       @unique @map("wizard_draft_design_id")
  wizardDraftDesignPairId String?       @unique @map("wizard_draft_design_pair_id")
  shopifyProductId        String?       @map("shopify_product_id")
  printifyProductId       String?       @map("printify_product_id")
  status                  ListingStatus @default(PUBLISHING)
  title                   String
  descriptionHtml         String        @map("description_html")
  tags                    String[]
  organizationCollections String[]      @default([]) @map("organization_collections")
  priceUsd                Float         @map("price_usd")
  publishedAt             DateTime?     @map("published_at")
  archivedAt              DateTime?     @map("archived_at")
  createdBy               String        @map("created_by")
  createdAt               DateTime      @default(now()) @map("created_at")

  store                 Store?                 @relation(fields: [storeId], references: [id], onDelete: SetNull)
  template              StoreMockupTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  wizardDraft           WizardDraft?           @relation(fields: [wizardDraftId], references: [id], onDelete: SetNull)
  wizardDraftDesign     WizardDraftDesign?     @relation(fields: [wizardDraftDesignId], references: [id], onDelete: SetNull)
  wizardDraftDesignPair WizardDraftDesignPair? @relation(fields: [wizardDraftDesignPairId], references: [id], onDelete: SetNull)
  variants              ListingVariant[]
  publishJobs           PublishJob[]

  @@index([tenantId, status])
  @@index([storeId])
  @@index([wizardDraftId])
  @@index([designId])
  @@map("listings")
}

model ListingVariant {
  id                String  @id @default(cuid())
  listingId         String  @map("listing_id")
  colorName         String  @map("color_name")
  colorHex          String  @map("color_hex")
  size              String  @default("ONE_SIZE")
  shopifyVariantId  String? @map("shopify_variant_id")
  printifyVariantId String? @map("printify_variant_id")
  sku               String?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_variants")
}

model PublishJob {
  id             String       @id @default(cuid())
  listingId      String       @map("listing_id")
  idempotencyKey String       @unique @map("idempotency_key")
  stage          PublishStage
  status         String       @default("PENDING")
  attempts       Int          @default(0)
  lastError      String?      @map("last_error")
  createdAt      DateTime     @default(now()) @map("created_at")
  completedAt    DateTime?    @map("completed_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("publish_jobs")
}

